        <xs:sequence>
            <xs:element name="item" type="xs:string" maxOccurs="unbounded"/>
            <xs:element name="quantity" type="xs:int"/>
        </xs:sequence>
    </xs:complexType>
    <xs:element name="Order" type="Order"/>
</xs:schema>
